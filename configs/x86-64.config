CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=960

# 启用 squashfs 文件系统 + sysupgrade.bin 生成
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_SYSUPGRADE=y  # 生成 sysupgrade.bin

CONFIG_ISO_IMAGES=n
CONFIG_QCOW2_IMAGES=n
CONFIG_VDI_IMAGES=n
CONFIG_VMDK_IMAGES=n
CONFIG_VHDX_IMAGES=n
CONFIG_TARGET_ROOTFS_TARGZ=n

CONFIG_KERNEL_KEXEC=y
CONFIG_PACKAGE_kexec=y
CONFIG_PACKAGE_kexec-tools=y

CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-gecoosac=n
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_luci-app-openlist2=n
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall2=n
CONFIG_PACKAGE_luci-app-openclash=n
# 启用 luci-app-timecontrol 插件（编译进固件）
CONFIG_PACKAGE_luci-app-timecontrol=y
